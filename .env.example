# Copy to credentials.env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,yourusername.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com

# Encryption key for stored credentials (OAuth tokens, service passwords, cookies).
# Optional: defaults to DJANGO_SECRET_KEY. If you set this, keep it STABLE across
# redeploys or previously-stored secrets become unreadable.
FIELD_ENCRYPTION_KEY=

# Database (SQLite default — fine for PythonAnywhere)
DATABASE_NAME=nexus.db

# Cerebras AI (replaces Anthropic)
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Public models as of 2026: gpt-oss-120b, zai-glm-4.7 (list via GET /v1/models)
CEREBRAS_MODEL_FAST=gpt-oss-120b
CEREBRAS_MODEL_STANDARD=gpt-oss-120b
CEREBRAS_MODEL_ADVANCED=zai-glm-4.7
CEREBRAS_MODEL_FALLBACK=gpt-oss-120b

# Google OAuth — connect Gmail + Classroom
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourusername.pythonanywhere.com/auth/google/callback

# NOTE: Veracross, Buzz/Accelerate and phone are now PER-USER — each person sets
# them in-app on their Account page (stored encrypted). The values below only seed
# the admin account on first migrate of an existing single-user deployment.

# Veracross — student portal login (per-user in-app after first run)
VERACROSS_URL=
VERACROSS_USERNAME=
VERACROSS_PASSWORD=

# Optional: Buzz / Accelerate (per-user in-app after first run)
BUZZ_DOMAIN=
BUZZ_USERNAME=
BUZZ_PASSWORD=
YOUR_PHONE_NUMBER=
USER_DISPLAY_NAME=

# Twilio — shared/admin (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
# Public HTTPS base for inbound SMS/WhatsApp replies (shared/admin)
PUBLIC_WEBHOOK_BASE=

# Admin Google account (can edit server credentials in app)
ADMIN_EMAIL=egor.alokhin@gmail.com
