# Copy to credentials.env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,yourusername.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com

# Database (SQLite default — fine for PythonAnywhere)
DATABASE_NAME=nexus.db

# Cerebras AI (replaces Anthropic)
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Google OAuth — connect Gmail + Classroom
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourusername.pythonanywhere.com/auth/google/callback

# Veracross — minimal setup for assignments
VERACROSS_URL=
VERACROSS_USERNAME=
VERACROSS_PASSWORD=

# Optional: Buzz / Accelerate
BUZZ_DOMAIN=
BUZZ_USERNAME=
BUZZ_PASSWORD=

# Optional: SMS via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
YOUR_PHONE_NUMBER=
USER_DISPLAY_NAME=
PUBLIC_WEBHOOK_BASE=

# Admin Google account (can edit server credentials in app)
ADMIN_EMAIL=egor.alokhin@gmail.com
